    "src/**/*.ts": [
      "node --max-old-space-size=4096 node_modules/.bin/eslint --cache --fix",
      "prettier --write"
    ],
    "scripts/**/*.ts": [
      "node --max-old-space-size=4096 node_modules/.bin/eslint --cache --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
