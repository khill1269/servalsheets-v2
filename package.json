    "lint": "NODE_OPTIONS='--max-old-space-size=8192' eslint src --cache --cache-location .eslintcache",
    "lint:fix": "NODE_OPTIONS='--max-old-space-size=8192' eslint src --fix --cache --cache-location .eslintcache",
    "metrics": "tsx scripts/show-metrics.ts",
    "monitor:dashboard": "bash scripts/launch-observability.sh",
    "monitor:errors": "tsx scripts/live-monitor.ts --errors",
    "monitor:health": "tsx scripts/test-health-monitoring.ts",
    "monitor:live": "tsx scripts/live-monitor.ts",
    "monitor:metrics": "tsx scripts/show-metrics.ts",
    "monitor:start": "bash scripts/start-monitoring.sh",
    "monitor:stats": "tsx scripts/live-monitor.ts --stats",
