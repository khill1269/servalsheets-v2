    "docs:site:dev": "npx vitepress dev docs",
    "docs:site:preview": "npx vitepress preview docs",
    "docs:spell": "cspell 'docs/**/*.md' --exclude 'docs/review/archive/**' --no-progress",
    "docs:spell:all": "cspell 'docs/**/*.md' '*.md' --exclude 'docs/review/archive/**' --exclude 'ServalSheets_*Audit_Report*.md' --no-progress",
    "docs:suggest-tags": "tsx scripts/suggest-tags.ts",
    "docs:sync": "node scripts/sync-doc-counts.mjs --fix",
    "docs:validate": "npm run docs:lint && npm run docs:check-links",
    "docs:watch": "typedoc --watch",
    "export-openapi": "tsx scripts/export-openapi.ts",
    "export-openapi:yaml": "tsx scripts/export-openapi.ts --format=yaml --output=docs/openapi.yaml",
    "fix:doc-action-counts": "bash scripts/fix-doc-action-counts.sh",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "gates": "bash scripts/validation-gates.sh",
    "gates:g0": "npm run typecheck && npm run lint && npm run check:drift && npm run test:fast",
    "gates:g1": "npm test -- --run tests/contracts/cross-map-consistency.test.ts && bash scripts/check-hardcoded-counts.sh",
    "gates:g2": "npm run test:handlers && npm run test:integration && npm run test:compliance",
    "gates:g3": "npm run validate:compliance && npm run docs:lint:baseline && npm run docs:check-links && npm run docs:freshness:ci",
    "gates:g4": "npm run build > /dev/null 2>&1 && node scripts/check-source-truth.mjs",
    "gates:g5": "npm run audit:quick > /dev/null 2>&1 && node scripts/check-audit-score.mjs",
