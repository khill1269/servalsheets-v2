    "validate:metadata": "tsx scripts/generate-metadata.ts --validate",
    "gen:openapi": "node --import tsx scripts/generate-openapi.ts",
    "gen:openapi:json": "node --import tsx scripts/generate-openapi.ts json",
    "gen:sdks": "tsx scripts/generate-sdks.ts",
    "gen:sdks:all": "npm run gen:openapi && npm run gen:sdks",
    "gen:sdks:go": "tsx scripts/generate-sdks.ts go",
    "gen:sdks:javascript": "tsx scripts/generate-sdks.ts javascript",
    "gen:sdks:python": "tsx scripts/generate-sdks.ts python",
    "gen:sdks:typescript": "tsx scripts/generate-sdks.ts typescript",
