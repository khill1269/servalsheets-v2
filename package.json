    "auth:setup": "node dist/cli.js --auth-setup",
    "bench": "RUN_BENCHMARKS=true vitest run tests/benchmarks",
    "bench:action-level": "TEST_REAL_API=true RUN_BENCHMARKS=true vitest run tests/benchmarks/live-api/action-level.bench.ts",
    "bench:adaptive": "tsx scripts/benchmarks/benchmark-adaptive-window.ts",
    "bench:full": "TEST_REAL_API=true RUN_BENCHMARKS=true vitest run tests/benchmarks/live-api tests/live-api/optimizations",
    "bench:handlers": "tsx scripts/benchmarks/benchmark-handlers.ts",
    "bench:live": "TEST_REAL_API=true RUN_BENCHMARKS=true vitest run tests/benchmarks/live-api",
    "bench:optimizations": "tsx scripts/benchmarks/benchmark-optimizations.ts",
    "bench:phase2": "RUN_BENCHMARKS=true vitest run tests/benchmarks/phase-2-performance.bench.ts",
    "bench:responses": "tsx scripts/benchmarks/benchmark-responses.ts",
    "bench:tool-level": "TEST_REAL_API=true RUN_BENCHMARKS=true vitest run tests/benchmarks/live-api/tool-level.bench.ts",
    "bench:worker-analysis": "tsx scripts/benchmarks/benchmark-worker-analysis.ts",
    "benchmark:http": "autocannon -c 100 -d 30 http://localhost:3000/health",
    "benchmarks:run": "RUN_BENCHMARKS=true vitest run tests/benchmarks && node scripts/track-benchmarks.mjs",
    "benchmarks:track": "vitest run tests/benchmarks && node scripts/track-benchmarks.mjs",
    "build": "npm run build:core && npm run gen:metadata && tsc -p tsconfig.build.json && npm run build:copy-assets",
    "build:full": "npm run build:core && npm run gen:metadata && npm run gen:openapi && tsc -p tsconfig.build.json && npm run build:copy-assets",
    "build:core": "npm run build --workspace @serval/core",
    "build:bundle": "bash scripts/build-bundle.sh",
    "build:clean": "npm run clean && npm run build",
    "build:copy-assets": "node scripts/copy-runtime-assets.mjs",
    "build:incremental": "tsc --build tsconfig.build.refs.json",
    "build:prod": "npm run gen:metadata && npm run gen:openapi && tsc -p tsconfig.production.json && npm run build:copy-assets",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "check": "npm run verify",
    "check:architecture": "depcruise --config .dependency-cruiser.cjs --output-type err src/",
    "check:architecture:graph": "depcruise --config .dependency-cruiser.cjs --output-type dot src/ | dot -T svg > architecture-graph.svg",
    "check:commit-size": "bash scripts/check-commit-size.sh",
    "check:dead-code": "knip --production",
    "check:dead-code:baseline": "node scripts/dead-code-triage.mjs --no-write --max-likely-dead=48 --max-wiring-candidates=0",
    "check:debug-prints": "bash scripts/check-debug-prints.sh",
    "check:file-sizes": "bash scripts/check-file-sizes.sh",
    "check:integration-wiring": "node scripts/check-integration-wiring.mjs",
    "check:mutation-actions": "node scripts/check-mutation-actions.mjs",
