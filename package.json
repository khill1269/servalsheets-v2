    "docs:freshness": "node --import tsx scripts/check-doc-freshness.ts",
    "docs:freshness:ci": "node --import tsx scripts/check-doc-freshness.ts --ci",
    "docs:freshness:json": "node --import tsx scripts/check-doc-freshness.ts --json",
    "docs:frontmatter": "tsx scripts/add-frontmatter.ts",
    "docs:frontmatter:check": "tsx scripts/check-frontmatter.ts docs/**/*.md",
    "docs:frontmatter:dry": "tsx scripts/add-frontmatter.ts --dry-run",
    "docs:frontmatter:force": "tsx scripts/add-frontmatter.ts --force",
    "docs:lint": "markdownlint-cli2 'docs/**/*.md' '#docs/archive/**' '#docs/review/archive/**' '#docs/generated/**' '#docs/.vitepress/**'",
