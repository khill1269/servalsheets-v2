{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../dist-tests",
    "noEmit": true,
    "types": ["vitest/globals", "node"],
    "paths": {
      "../../src/*": ["../src/*"],
      "../src/*": ["../src/*"],
      "./src/*": ["../src/*"]
    }
  },
  "include": ["./**/*", "../src/**/*"],
  "exclude": ["../node_modules", "../dist"]
}
