    "docs:lint:baseline:update": "node scripts/check-markdownlint-baseline.mjs --update",
    "docs:lint:fix": "markdownlint-cli2 --fix 'docs/**/*.md' '#docs/archive/**' '#docs/review/archive/**' '#docs/generated/**'",
    "docs:lint:root": "markdownlint-cli2 '*.md' '#CHANGELOG.md' '#ServalSheets_*Audit_Report*.md'",
    "docs:metrics": "tsx scripts/generate-doc-metrics.ts",
    "docs:prose": "vale docs --glob='*.md' --ignore-syntax || echo '💡 Install Vale: brew install vale (macOS) or see .vale/README.md'",
    "docs:prose:sync": "vale sync || echo '💡 Vale not installed. See .vale/README.md for setup instructions'",
