    "replay:run": "tsx src/cli/replay.ts run",
    "replay:batch": "tsx src/cli/replay.ts batch",
    "replay:stats": "tsx src/cli/replay.ts stats",
    "replay:cleanup": "tsx src/cli/replay.ts cleanup",
