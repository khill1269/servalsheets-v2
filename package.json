  "scripts": {
    "analyze:all": "tsx scripts/analysis/cli.ts analyze src",
    "analyze:dir": "tsx scripts/analysis/cli.ts analyze",
    "analyze:file": "tsx scripts/analysis/cli.ts analyze",
    "analyze:fix": "tsx scripts/analysis/auto-fixer.ts",
    "analyze:quick": "tsx scripts/analysis/cli.ts analyze --exclude=CodeQuality,Testing,Consistency,Security,DocumentationValidator",
    "analyze:report": "tsx scripts/analysis/cli.ts report",
    "analyze:security": "tsx scripts/analysis/cli.ts analyze --exclude=PatternRecognition,CodeQuality,TypeSafety,Testing,Consistency,DocumentationValidator",
    "analyze:watch": "tsx scripts/analysis/cli.ts watch",
    "audit:coverage": "vitest run tests/audit/action-coverage.test.ts",
    "audit:full": "npm run audit:coverage && npm run audit:perf && npm run audit:memory && npm run audit:snapshot && npm run audit:google-api",
