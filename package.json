    "check:metadata-strict": "node --import tsx scripts/check-metadata-strict.ts",
    "check:placeholders": "bash scripts/no-placeholders.sh",
    "check:release-surface": "node --import tsx scripts/check-release-surface.ts",
    "check:source-dist-consistency": "node --import tsx scripts/check-source-dist-consistency.ts",
    "check:silent-fallbacks": "bash scripts/check-silent-fallbacks.sh",
    "check:worktree": "bash scripts/check-worktree-hygiene.sh",
    "ci": "npm run clean && turbo run build verify && npm run validate:server-json && npm run smoke",
    "ci:legacy": "npm run clean && npm run build && npm run verify:legacy && npm run validate:server-json && npm run smoke",
    "clean": "rm -rf dist .tsbuildinfo .tsbuildinfo.build",
    "clean:agent-context": "rm -rf .agent-context/*.json && echo '✅ Agent context cleaned'",
    "claude:logs": "node --import tsx scripts/analyze-claude-code-debug.ts",
    "claude:logs:quick": "node --import tsx scripts/analyze-claude-code-debug.ts --max-files=30",
    "claude:logs:desktop": "node --import tsx scripts/analyze-claude-logs.ts",
    "claude:learn": "node --import tsx scripts/analyze-claude-code-debug.ts --max-files=120 && echo '✅ Updated .agent-context/learning-memory.md'",
