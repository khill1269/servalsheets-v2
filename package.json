    "dashboard:generate": "tsx scripts/generate-dashboard.ts",
    "dead-code": "ts-prune --ignore 'src/(index|cli|server|http-server|remote-server).ts|.*.test.ts' --error",
    "dead-code:report": "node scripts/dead-code-triage.mjs",
    "dead-code:report:raw": "ts-prune --ignore 'src/(index|cli|server|http-server|remote-server).ts|src/.*/index.ts|packages/serval-core/dist/.*|.*.test.ts'",
    "demo:generate": "bash scripts/demo/generate-demo.sh",
    "demo:record": "bash scripts/demo/record-demo.sh",
    "deps:check": "syncpack lint",
    "deps:fix": "syncpack fix",
    "deps:format": "syncpack format",
    "deps:update": "syncpack update --interactive",
    "dev": "tsx watch src/cli.ts",
    "dev:fast": "node scripts/dev-server.mjs",
    "dev:watch": "node scripts/dev-server.mjs --watch",
